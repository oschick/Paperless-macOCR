# Paperless-NGX connection
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=your-api-token-here

# macOCR HTTP server or iOS-OCR-Server connection
# Both use the same /upload API and are interchangeable.
# macOCR:          http://host.docker.internal:8080
# iOS-OCR-Server:  http://<iphone-ip>:8000
MACOCR_URL=http://host.docker.internal:8080
# Optional: macOCR HTTP Basic Auth (username:password) — not used by iOS-OCR-Server
MACOCR_AUTH=

# Webhook server settings
HOST=0.0.0.0
PORT=9000

# Optional: shared secret for webhook verification
WEBHOOK_SECRET=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OCR settings
# DPI for PDF page to image conversion (higher = better quality, slower)
OCR_DPI=300
# Whether to skip documents that already have extractable text
SKIP_IF_TEXT_PRESENT=true
# Replace the document in Paperless with a searchable PDF containing
# an invisible text layer from macOCR (uploads new doc, copies metadata,
# deletes old).  Requires PAPERLESS_OCR_MODE=skip in Paperless config
# so the re-uploaded PDF is not re-OCR'd by Paperless.
REPLACE_PDF=false
# Comma-separated tag names or IDs to remove from the replacement document after
# a searchable PDF is built (e.g. "Inbox" or "1,5").  Leave empty to keep all tags.
REPLACE_PDF_REMOVE_TAGS=

# ── Web UI ──────────────────────────────────────────────────────────────────────

# Enable or disable the web UI (default: true)
WEB_UI_ENABLED=true

# Authentication mode: none | basic | oidc
WEB_UI_AUTH=none

# Basic auth credentials (when WEB_UI_AUTH=basic)
WEB_UI_USERNAME=admin
WEB_UI_PASSWORD=

# Session signing secret — required for basic and oidc auth.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-production

# Comma-separated tag IDs to hide from the document list
# (e.g. sensitive or archived document tags)
WEB_UI_EXCLUDE_TAGS=

# ── OIDC / OAuth2 (when WEB_UI_AUTH=oidc) ───────────────────────────────────

# OAuth2 / OIDC client ID and secret from your identity provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# OIDC discovery URL (.well-known/openid-configuration)
# Authentik: https://<authentik-host>/application/o/<app-slug>/.well-known/openid-configuration
# Keycloak:  https://<keycloak-host>/realms/<realm>/.well-known/openid-configuration
OIDC_DISCOVERY_URL=

# Redirect URI registered with your identity provider
# Leave empty to auto-detect from the incoming request
OIDC_REDIRECT_URI=
