# Paperless-NGX connection
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=your-api-token-here

# macOCR HTTP server or iOS-OCR-Server connection
# Both use the same /upload API and are interchangeable.
# macOCR:          http://host.docker.internal:8080
# iOS-OCR-Server:  http://<iphone-ip>:8000
MACOCR_URL=http://host.docker.internal:8080
# Optional: macOCR HTTP Basic Auth (username:password) — not used by iOS-OCR-Server
MACOCR_AUTH=

# Webhook server settings
HOST=0.0.0.0
PORT=9000

# Optional: shared secret for webhook verification
WEBHOOK_SECRET=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OCR settings
# DPI for PDF page to image conversion (higher = better quality, slower)
OCR_DPI=300
# Whether to skip documents that already have extractable text
SKIP_IF_TEXT_PRESENT=true
# Replace the document in Paperless with a searchable PDF containing
# an invisible text layer from macOCR (uploads new doc, copies metadata,
# deletes old).  Requires PAPERLESS_OCR_MODE=skip in Paperless config
# so the re-uploaded PDF is not re-OCR'd by Paperless.
REPLACE_PDF=false
